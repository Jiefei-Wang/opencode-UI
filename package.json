{
  "name": "opencode-vscode",
  "displayName": "OpenCode",
  "description": "OpenCode coding agent for VS Code Chat and side panel.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:opencode.openChat",
    "onCommand:opencode.openPanel",
    "onCommand:opencode.newSession",
    "onCommand:opencode.resumeSession",
    "onCommand:opencode.pickAgent",
    "onCommand:opencode.pickSkill",
    "onCommand:opencode.pickModel",
    "onCommand:opencode.showTodo",
    "onCommand:opencode.showDiff",
    "onCommand:opencode.abort",
    "onCommand:opencode.restartServer",
    "onCommand:opencode.checkEnvironment",
    "onCommand:opencode.openOutput",
    "onView:opencode.secondaryPanel"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "test": "tsc --noEmit && node esbuild.tests.js && node --test .test-dist/*.test.js tests/*.test.js",
    "test:vscode": "npm run compile && node esbuild.vscode-tests.js && vscode-test --config .vscode-test.js",
    "smoke:opencode": "node scripts/smoke-opencode-api.js",
    "watch": "node esbuild.js --watch",
    "package": "tsc --noEmit && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "opencode.opencode",
        "fullName": "OpenCode",
        "name": "opencode",
        "description": "Ask OpenCode to work in this workspace",
        "isSticky": true,
        "commands": [
          {
            "name": "new",
            "description": "Start a new OpenCode session"
          },
          {
            "name": "resume",
            "description": "Resume an existing session"
          },
          {
            "name": "sessions",
            "description": "List recent sessions"
          },
          {
            "name": "agent",
            "description": "Choose or insert an agent"
          },
          {
            "name": "skill",
            "description": "Choose or insert a skill"
          },
          {
            "name": "model",
            "description": "Choose provider and model"
          },
          {
            "name": "todo",
            "description": "Show current todos"
          },
          {
            "name": "diff",
            "description": "Show current modified files"
          },
          {
            "name": "abort",
            "description": "Abort the active OpenCode run"
          },
          {
            "name": "permissions",
            "description": "Review pending permissions"
          },
          {
            "name": "status",
            "description": "Show OpenCode server status"
          }
        ]
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "opencodeSecondaryViewContainer",
          "title": "OpenCode",
          "icon": "media/opencode.svg"
        }
      ]
    },
    "views": {
      "opencodeSecondaryViewContainer": [
        {
          "id": "opencode.secondaryPanel",
          "name": "OpenCode",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode.openChat",
        "title": "OpenCode: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "opencode.openPanel",
        "title": "OpenCode: Open Panel",
        "icon": "$(hubot)"
      },
      {
        "command": "opencode.newSession",
        "title": "OpenCode: New Session",
        "icon": "$(add)"
      },
      { "command": "opencode.status.ready",    "title": "Ready" },
      { "command": "opencode.status.busy",     "title": "Working..." },
      { "command": "opencode.status.starting", "title": "Starting..." },
      { "command": "opencode.status.stopped",  "title": "Stopped" },
      { "command": "opencode.status.error",    "title": "Error" },
      {
        "command": "opencode.resumeSession",
        "title": "OpenCode: Resume Session",
        "icon": "$(history)"
      },
      {
        "command": "opencode.pickAgent",
        "title": "OpenCode: Pick Agent",
        "icon": "$(account)"
      },
      {
        "command": "opencode.pickSkill",
        "title": "OpenCode: Pick Skill",
        "icon": "$(sparkle)"
      },
      {
        "command": "opencode.pickModel",
        "title": "OpenCode: Pick Model",
        "icon": "$(server-process)"
      },
      {
        "command": "opencode.showTodo",
        "title": "OpenCode: Show Todo",
        "icon": "$(checklist)"
      },
      {
        "command": "opencode.showDiff",
        "title": "OpenCode: Show Diff",
        "icon": "$(diff)"
      },
      {
        "command": "opencode.abort",
        "title": "OpenCode: Abort",
        "icon": "$(debug-stop)"
      },
      {
        "command": "opencode.restartServer",
        "title": "OpenCode: Restart Server",
        "icon": "$(debug-restart)"
      },
      {
        "command": "opencode.checkEnvironment",
        "title": "OpenCode: Check Environment",
        "icon": "$(debug-alt)"
      },
      {
        "command": "opencode.openOutput",
        "title": "OpenCode: Open Output",
        "icon": "$(output)"
      }
    ],
    "submenus": [
      {
        "id": "opencode.panelMenu",
        "label": "OpenCode",
        "icon": "$(ellipsis)"
      },
      {
        "id": "opencode.panelMenu.sessions",
        "label": "Sessions"
      },
      {
        "id": "opencode.panelMenu.selection",
        "label": "Selection"
      },
      {
        "id": "opencode.panelMenu.workspace",
        "label": "Workspace"
      },
      {
        "id": "opencode.panelMenu.control",
        "label": "Control"
      },
      {
        "id": "opencode.panelMenu.diagnostics",
        "label": "Diagnostics"
      }
    ],
    "menus": {
      "view/title": [
        { "command": "opencode.status.ready",    "when": "view == opencode.secondaryPanel && opencode.serverState == 'ready'",    "group": "navigation@0" },
        { "command": "opencode.status.busy",     "when": "view == opencode.secondaryPanel && opencode.serverState == 'busy'",     "group": "navigation@0" },
        { "command": "opencode.status.starting", "when": "view == opencode.secondaryPanel && opencode.serverState == 'starting'", "group": "navigation@0" },
        { "command": "opencode.status.stopped",  "when": "view == opencode.secondaryPanel && opencode.serverState == 'stopped'",  "group": "navigation@0" },
        { "command": "opencode.status.error",    "when": "view == opencode.secondaryPanel && opencode.serverState == 'error'",    "group": "navigation@0" },
        {
          "command": "opencode.newSession",
          "when": "view == opencode.secondaryPanel",
          "group": "navigation@1"
        },
        {
          "command": "opencode.restartServer",
          "when": "view == opencode.secondaryPanel",
          "group": "navigation@2"
        },
        {
          "submenu": "opencode.panelMenu",
          "when": "view == opencode.secondaryPanel",
          "group": "navigation@3"
        }
      ],
      "opencode.panelMenu": [
        {
          "submenu": "opencode.panelMenu.sessions",
          "group": "1_sessions"
        },
        {
          "submenu": "opencode.panelMenu.selection",
          "group": "2_selection"
        },
        {
          "submenu": "opencode.panelMenu.workspace",
          "group": "3_workspace"
        },
        {
          "submenu": "opencode.panelMenu.control",
          "group": "4_control"
        },
        {
          "submenu": "opencode.panelMenu.diagnostics",
          "group": "5_diagnostics"
        }
      ],
      "opencode.panelMenu.sessions": [
        {
          "command": "opencode.openChat",
          "group": "navigation@1"
        },
        {
          "command": "opencode.openPanel",
          "group": "navigation@2"
        },
        {
          "command": "opencode.newSession",
          "group": "navigation@3"
        },
        {
          "command": "opencode.resumeSession",
          "group": "navigation@4"
        }
      ],
      "opencode.panelMenu.selection": [
        {
          "command": "opencode.pickAgent",
          "group": "navigation@1"
        },
        {
          "command": "opencode.pickSkill",
          "group": "navigation@2"
        },
        {
          "command": "opencode.pickModel",
          "group": "navigation@3"
        }
      ],
      "opencode.panelMenu.workspace": [
        {
          "command": "opencode.showTodo",
          "group": "navigation@1"
        },
        {
          "command": "opencode.showDiff",
          "group": "navigation@2"
        }
      ],
      "opencode.panelMenu.control": [
        {
          "command": "opencode.abort",
          "group": "navigation@1"
        },
        {
          "command": "opencode.restartServer",
          "group": "navigation@2"
        }
      ],
      "opencode.panelMenu.diagnostics": [
        {
          "command": "opencode.checkEnvironment",
          "group": "navigation@1"
        },
        {
          "command": "opencode.openOutput",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "OpenCode",
      "properties": {
        "opencode.executablePath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Optional opencode executable path. Leave empty to resolve opencode from PATH."
        },
        "opencode.autoStart": {
          "type": "string",
          "default": "onWorkspaceOpen",
          "enum": [
            "onFirstUse",
            "onWorkspaceOpen"
          ],
          "scope": "window",
          "description": "When to start the OpenCode server."
        },
        "opencode.httpProxy": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Optional HTTP proxy used when launching opencode serve."
        },
        "opencode.defaultAgent": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Optional default OpenCode agent name."
        },
        "opencode.defaultModel": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Optional default model in provider/model format."
        },
        "opencode.showThinking": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Show reasoning/thinking parts when OpenCode provides them."
        },
        "opencode.richPanel.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Enable the OpenCode side panel."
        }
      }
    }
  }
}
